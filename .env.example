# LLM Config - swap between local Ollama and Groq
# Dev (local Ollama):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2

# Prod (Groq free tier):
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# Cerebras (fast LLM fallback)
CEREBRAS_API_KEY=

# X/Twitter API (Free Tier)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# CoinGecko (free demo key)
COINGECKO_API_KEY=

# Bot control
TWEET_BOT_ENABLED=true
